# /etc/jaah/vm-secrets.env  — REAL FILE MUST BE: root:600, /etc/jaah/ must be root:700
#
# Copy this template to /etc/jaah/vm-secrets.env on each cluster node:
#     install -d -o root -g root -m 700 /etc/jaah
#     install -o root -g root -m 600 vm-secrets.env.example /etc/jaah/vm-secrets.env
#     vim /etc/jaah/vm-secrets.env       # fill in real values
#
# And place the default SSH public key:
#     install -d -o root -g root -m 755 /etc/jaah/keys
#     install -o root -g root -m 644 ~/.ssh/id_ed25519.pub /etc/jaah/keys/default.pub

# Password used ONLY when create --set-password is passed. Default flow is SSH-key-only.
# NEVER ends up in process argv (passed via cloud-init --cicustom file).
VM_DEFAULT_PASSWORD='change-me-strong-passphrase'
