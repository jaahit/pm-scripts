#!/bin/bash
# jaah-vm — Mini AWS-EC2-style VM launcher for the jaah Proxmox cluster.
#
# Subcommands:
#   wizard   — ★ Interactive 5-step VM creation (whiptail TUI)
#   create   — Non-interactive: launch a new Ubuntu 26.04 cloud-init VM
#   rerun    — Replay the exact recipe of an existing managed VM
#   list     — Show all VMs managed by jaah-vm
#   status   — Show details for one managed VM
#   shell    — SSH into a managed VM
#   destroy  — Terminate a managed VM (manifest-verified, typed confirm)
#   doctor   — Cluster + tool health check
#   types    — Show instance-type presets
#
# See `jaah-vm --help` and `jaah-vm <subcommand> --help`.

readonly JAAH_VM_VERSION="0.4.6"
export JAAH_VM_VERSION

# Resolve installed lib path; fall back to repo-local for development.
_resolve_lib() {
    local self_dir
    self_dir=$(dirname "$(readlink -f "$0")")
    for p in /usr/local/lib/jaah-vm/lib-common.sh "${self_dir}/lib-common.sh"; do
        [ -r "$p" ] && { echo "$p"; return 0; }
    done
    echo ""
}

_LIB=$(_resolve_lib)
if [ -z "$_LIB" ]; then
    echo "FATAL: lib-common.sh not found" >&2
    exit 1
fi
# shellcheck source=lib-common.sh
. "$_LIB"

# ────────────────────────────────────────────────────────────────────────────
# Cheat sheet (no-args)
# ────────────────────────────────────────────────────────────────────────────

show_cheatsheet() {
    cat <<'EOF'
jaah-vm — Mini EC2 Launch Wizard for jaah-cluster

★ EASIEST — INTERACTIVE WIZARD:
    jaah-vm wizard                                  # 5-step guided creation

NON-INTERACTIVE / SCRIPTED:
    jaah-vm create --name web-01                    # default: type=small, key-only
    jaah-vm create --name db-01 --type large --start --wait-ssh

MANAGE:
